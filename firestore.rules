rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isTestNumber(phone) {
      return phone in ['+254755881991', '+254105845108', '0755881991', '0105845108', '0793717860', '+254793717860'];
    }

    function hasRole(id, roles) {
      return exists(/databases/$(database)/documents/users/$(id)) && 
             get(/databases/$(database)/documents/users/$(id)).data.role in roles;
    }

    function checkAuthComplex(roles) {
      let uid = request.auth.uid;
      let phone = request.auth.token.phone_number;
      return hasRole(uid, roles) ||
             (uid.size() == 10 && (hasRole('+254' + uid[1:10], roles) || hasRole('254' + uid[1:10], roles))) ||
             (uid.size() == 13 && hasRole('0' + uid[4:13], roles)) ||
             (uid.size() == 12 && hasRole('0' + uid[3:12], roles)) ||
             (phone != null && (
               hasRole(phone, roles) ||
               (phone.size() == 10 && (hasRole('+254' + phone[1:10], roles) || hasRole('254' + phone[1:10], roles))) ||
               (phone.size() == 13 && hasRole('0' + phone[4:13], roles)) ||
               (phone.size() == 12 && hasRole('0' + phone[3:12], roles))
             ));
    }

    function isAdmin() {
      return checkAuthComplex(['admin', 'super_master']) ||
             isTestNumber(request.auth.uid) ||
             (request.auth.token.phone_number != null && isTestNumber(request.auth.token.phone_number));
    }

    function isProfessional() {
      return checkAuthComplex(['agent', 'master_agent', 'super_master', 'admin']);
    }

    function isOwner(userId) {
      let uid = request.auth.uid;
      let phone = request.auth.token.phone_number;
      return uid == userId || 
             (phone != null && phone == userId) ||
             // Local doc ID (07...) matching Intl UIDs
             (userId.size() == 10 && (uid == '+254' + userId[1:10] || uid == '254' + userId[1:10] || (phone != null && (phone == '+254' + userId[1:10] || phone == '254' + userId[1:10])))) ||
             // Intl doc ID (+254...) matching Local UIDs
             (userId.size() == 13 && (uid == '0' + userId[4:13] || (phone != null && phone == '0' + userId[4:13]))) ||
             // Intl doc ID (254...) matching Local UIDs
             (userId.size() == 12 && (uid == '0' + userId[3:12] || (phone != null && phone == '0' + userId[3:12])));
    }

    // Users collection
    match /users/{userId} {
      // Direct bypass for test numbers to ensure they can manage their profiles
      allow read, write: if isAuthenticated() && (
        isTestNumber(request.auth.uid) || 
        (request.auth.token.phone_number != null && isTestNumber(request.auth.token.phone_number))
      );

      // Users can read/write their own profile
      allow read, update: if isAuthenticated() && (
        isOwner(userId) ||
        (resource != null && resource.data.uid == request.auth.uid)
      );
      
      allow create: if isAuthenticated();
      allow read, create, update: if isAuthenticated() && isAdmin();
    }
    
    // Dependents collection
    match /dependents/{depId} {
      allow read, write: if isAuthenticated() && (
        resource == null || 
        isOwner(resource.data.guardian_id) || 
        isOwner(request.resource.data.guardian_id)
      );
      allow read, write: if isAuthenticated() && isAdmin();
    }
    
    // Claims collection
    match /claims/{claimId} {
      allow create: if isAuthenticated() && isOwner(request.resource.data.guardian_id);
      allow read: if isAuthenticated() && isOwner(resource.data.guardian_id);
      allow read, update: if isAuthenticated() && isAdmin();
    }
    
    // Transactions collection
    match /transactions/{transId} {
      allow read: if isAuthenticated() && isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
      allow read: if isAuthenticated() && isAdmin();
      allow update, delete: if false;
    }

    match /agents/{agentId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin();
    }

    match /master_agents/{masterId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin();
    }

    function isAgent(code) {
      let uid = request.auth.uid;
      let phone = request.auth.token.phone_number;
      return (exists(/databases/$(database)/documents/users/$(uid)) && get(/databases/$(database)/documents/users/$(uid)).data.agent_code == code) ||
             (uid.size() == 10 && exists(/databases/$(database)/documents/users/$( '254' + uid[1:10] )) && get(/databases/$(database)/documents/users/$( '254' + uid[1:10] )).data.agent_code == code) ||
             (uid.size() == 12 && exists(/databases/$(database)/documents/users/$( '0' + uid[3:12] )) && get(/databases/$(database)/documents/users/$( '0' + uid[3:12] )).data.agent_code == code) ||
             (phone != null && (
               (exists(/databases/$(database)/documents/users/$(phone)) && get(/databases/$(database)/documents/users/$(phone)).data.agent_code == code) ||
               (phone.size() == 10 && exists(/databases/$(database)/documents/users/$( '254' + phone[1:10] )) && get(/databases/$(database)/documents/users/$( '254' + phone[1:10] )).data.agent_code == code) ||
               (phone.size() == 12 && exists(/databases/$(database)/documents/users/$( '0' + phone[3:12] )) && get(/databases/$(database)/documents/users/$( '0' + phone[3:12] )).data.agent_code == code)
             ));
    }

    match /recruitment_logs/{logId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.agentId) || isAgent(resource.data.agentId) || isAdmin()
      );
      allow create: if isAuthenticated() && isProfessional();
    }

    match /withdrawals/{wdId} {
       allow read, create: if isAuthenticated() && (
         isOwner(resource.data.userId) || 
         isOwner(request.resource.data.userId) ||
         isAdmin()
       );
    }

    match /config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin();
    }

    match /totals/{totalId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin();
    }

    match /sifuna_kb/{kbId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin();
    }
  }
}
