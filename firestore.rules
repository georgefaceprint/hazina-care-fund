rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAdmin() {
      let role = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return role == 'admin' || role == 'super_master';
    }

    // Users collection
    match /users/{userId} {
      // Users can read/write their own profile
      allow read, update: if isAuthenticated() && isOwner(userId);
      // New users can create their profile
      allow create: if isAuthenticated() && isOwner(userId);
      // Admins and Super Masters can read and manage all users
      allow read, create, update: if isAuthenticated() && isAdmin();
    }
    
    // Dependents collection
    match /dependents/{depId} {
      // Users can read/write dependents they manage
      allow read, write: if isAuthenticated() && (resource == null || resource.data.guardian_id == request.auth.uid || request.resource.data.guardian_id == request.auth.uid);
      // Admins can manage all dependents
      allow read, write: if isAuthenticated() && isAdmin();
    }
    
    // Claims collection
    match /claims/{claimId} {
      // Users can create claims and read their own
      allow create: if isAuthenticated() && request.resource.data.guardian_id == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.guardian_id == request.auth.uid;
      // Admins can read and update (approve/reject) all claims
      allow read, update: if isAuthenticated() && isAdmin();
    }
    
    // Transactions collection
    match /transactions/{transId} {
      // Users can read their own transactions
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Transactions are append-only for users (via server logic/functions eventually)
      // For now, allow create if attributed correctly
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Admins can read all transactions
      allow read: if isAuthenticated() && isAdmin();
      // Prevents deletion or modification of history
      allow update, delete: if false;
    }
    // Recruitment System
    match /agents/{agentId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'master_agent' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_master');
    }

    match /master_agents/{masterId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_master');
    }

    match /recruitment_logs/{logId} {
      allow read: if isAuthenticated() && (
        resource.data.agentId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.agent_code ||
        resource.data.masterAgentId == request.auth.uid ||
        isAdmin() || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_master'
      );
      allow create: if true; // Allow creation for recruitment tracking (can be restricted further if needed)
    }

    // Config Collection
    match /config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin();
    }

    // Totals/Global Metrics
    match /totals/{totalId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin();
    }

    // Sifuna Knowledge Base
    match /sifuna_kb/{kbId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin();
    }
  }
}
