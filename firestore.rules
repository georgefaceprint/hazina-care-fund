rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAdmin() {
      return (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
              (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_master')) || 
             (request.auth.token.phone_number != null && 
              exists(/databases/$(database)/documents/users/$(request.auth.token.phone_number)) && 
              (get(/databases/$(database)/documents/users/$(request.auth.token.phone_number)).data.role == 'admin' || 
               get(/databases/$(database)/documents/users/$(request.auth.token.phone_number)).data.role == 'super_master'));
    }

    // Users collection
    match /users/{userId} {
      // Users can read/write their own profile
      // Supports both UID-based IDs and Phone-based IDs by checking the internal uid field
      allow read, update: if isAuthenticated() && (
        request.auth.uid == userId || 
        (resource != null && resource.data.uid == request.auth.uid)
      );
      
      // New users can create their profile
      allow create: if isAuthenticated() && (
        request.auth.uid == userId || 
        request.resource.data.uid == request.auth.uid
      );

      // Admins and Super Masters can read and manage all users
      allow read, create, update: if isAuthenticated() && isAdmin();
    }
    
    // Dependents collection
    match /dependents/{depId} {
      // Users can read/write dependents they manage
      allow read, write: if isAuthenticated() && (resource == null || resource.data.guardian_id == request.auth.uid || request.resource.data.guardian_id == request.auth.uid);
      // Admins can manage all dependents
      allow read, write: if isAuthenticated() && isAdmin();
    }
    
    // Claims collection
    match /claims/{claimId} {
      // Users can create claims and read their own
      allow create: if isAuthenticated() && request.resource.data.guardian_id == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.guardian_id == request.auth.uid;
      // Admins can read and update (approve/reject) all claims
      allow read, update: if isAuthenticated() && isAdmin();
    }
    
    // Transactions collection
    match /transactions/{transId} {
      // Users can read their own transactions
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Transactions are append-only for users (via server logic/functions eventually)
      // For now, allow create if attributed correctly
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Admins can read all transactions
      allow read: if isAuthenticated() && isAdmin();
      // Prevents deletion or modification of history
      allow update, delete: if false;
    }
    // Recruitment System
    match /agents/{agentId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'master_agent' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_master');
    }

    match /master_agents/{masterId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_master');
    }

    match /recruitment_logs/{logId} {
      allow read: if isAuthenticated() && (
        // Allow if agentId matches user's agent_code OR local phone OR UID
        resource.data.agentId == request.auth.uid ||
        (request.auth.token.phone_number != null && (
          resource.data.agentId == request.auth.token.phone_number.replace('^\\+254', '0') ||
          resource.data.agentId == request.auth.token.phone_number.replace('^254', '0')
        )) ||
        
        // Profile-based matches (UID login)
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          resource.data.agentId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.agent_code ||
          resource.data.agentId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.phoneNumber // Already standardized to 0...
        )) ||

        // Master Agent check
        resource.data.masterAgentId == request.auth.uid ||
        (request.auth.token.phone_number != null && resource.data.masterAgentId == request.auth.token.phone_number.replace('^\\+254', '0')) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          resource.data.masterAgentId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.phoneNumber) ||

        // Admin overrides
        isAdmin() || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_master'
      );
      allow create: if true;
    }

    // Config Collection
    match /config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin();
    }

    // Totals/Global Metrics
    match /totals/{totalId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin();
    }

    // Sifuna Knowledge Base
    match /sifuna_kb/{kbId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin();
    }
  }
}
